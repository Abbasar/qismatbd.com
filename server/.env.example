NODE_ENV=development

DB_HOST=localhost
# cPanel MySQL user is usually prefixed — use the user you attached to the database.
DB_USER=root
DB_PASSWORD=yourpassword
DB_DATABASE=qismyirz_qismat
PORT=4000

# Public URL of this Node API (no trailing slash). SSLCommerz / Steadfast callbacks use BACKEND_URL.
BACKEND_URL=http://localhost:4000
FRONTEND_URL=http://localhost:5173

# Production: required — comma-separated storefront origins (no trailing slash). www and non-www both if you use both.
# CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

JWT_SECRET=very_long_random_secret_here

GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret