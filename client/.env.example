# Dev: leave unset or use empty string so `npm run dev` uses same-origin /api (Vite proxy → Express).
# Production build: use `client/.env.production` (see `.env.production.example`), then `npm run build`.
VITE_API_URL=http://localhost:4000
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
